# ─── API Keys ─────────────────────────────────────
# Get your EURI API key from: https://euron.one
EURI_API_KEY=your_euri_api_key_here

# Get your Pinecone API key from: https://www.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-east-1

# ─── Database ─────────────────────────────────────
# MongoDB Atlas connection URI
# Replace <username>, <password>, and <cluster-url> with your Atlas credentials
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/rag_chatbot?retryWrites=true&w=majority
